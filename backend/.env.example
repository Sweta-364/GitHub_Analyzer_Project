# Copy this file to .env and fill in your values

# PostgreSQL — use your Supabase connection string (Transaction mode, port 6543)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Redis — use your Upstash Redis URL (rediss:// for TLS)
REDIS_URL=rediss://default:your_token@your_host.upstash.io:6379

# GitHub personal access token (optional but recommended — raises limit 60→5000/hr)
# Create at https://github.com/settings/tokens  (no scopes needed for public data)
GITHUB_TOKEN=

# Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# App
APP_VERSION=0.1.0
